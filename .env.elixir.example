# Copy to .env.elixir and fill in your values
# Do NOT commit .env.elixir to git

# Phoenix
SECRET_KEY_BASE=replace_with_64_char_random_string
PHX_HOST=localhost

# JWT
JWT_SECRET=replace_with_random_secret

# Embedding — choose one backend
EMBED_BACKEND=voyage
EMBED_MODEL=voyage-4-large
EMBED_DIMS=1024
VOYAGE_API_KEY=

# OR for local Ollama:
# EMBED_BACKEND=ollama
# EMBED_MODEL=nomic-embed-text
# EMBED_DIMS=768
# OLLAMA_URL=http://host.docker.internal:11434

# Qdrant (use Cloud for SaaS, localhost:6333 for local)
QDRANT_URL=https://your-cluster.qdrant.tech
QDRANT_API_KEY=
QDRANT_COLLECTION=obsidian_notes

# Erlang clustering (can be random for single-node dev)
RELEASE_COOKIE=dev_cookie_replace_in_prod
