# Copy to .env.elixir and fill in your values
# Do NOT commit .env.elixir to git

# Phoenix
SECRET_KEY_BASE=replace_with_64_char_random_string
PHX_HOST=localhost

# JWT
JWT_SECRET=replace_with_random_secret

# Embedding — choose one backend
EMBED_BACKEND=voyage
EMBED_MODEL=voyage-4-large
EMBED_DIMS=1024
VOYAGE_API_KEY=

# Asymmetric retrieval (optional — falls back to EMBED_MODEL if unset)
DOC_EMBED_MODEL=voyage-4-large
QUERY_EMBED_MODEL=voyage-4-lite

# OR for local Ollama:
# EMBED_BACKEND=ollama
# EMBED_MODEL=nomic-embed-text
# EMBED_DIMS=768
# OLLAMA_URL=http://host.docker.internal:11434

# Qdrant (1024d with binary quantization)
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=obsidian_notes

# Storage — choose one backend
STORAGE_BACKEND=s3
STORAGE_BUCKET=engram-attachments
STORAGE_ACCESS_KEY_ID=minioadmin
STORAGE_SECRET_ACCESS_KEY=minioadmin
STORAGE_SCHEME=http://
STORAGE_HOST=localhost
STORAGE_PORT=9000
STORAGE_REGION=us-east-1

# OR for database storage (default, no S3 needed):
# STORAGE_BACKEND=database

# Clerk auth (optional for dev)
# CLERK_JWKS_URL=https://your-instance.clerk.accounts.dev/.well-known/jwks.json
# CLERK_ISSUER=https://your-instance.clerk.accounts.dev

# Erlang clustering (can be random for single-node dev)
RELEASE_COOKIE=dev_cookie_replace_in_prod
