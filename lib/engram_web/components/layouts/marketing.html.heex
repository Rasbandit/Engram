<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Engram — Your Second Brain, Powered by AI</title>
  <link rel="stylesheet" href="/css/marketing.css" />
</head>
<body class="min-h-screen bg-white text-gray-900 flex flex-col">
  <header class="border-b border-gray-200">
    <nav class="max-w-5xl mx-auto px-6 py-4 flex items-center justify-between">
      <a href="/" class="text-xl font-bold tracking-tight">Engram</a>
      <ul class="flex items-center gap-6 text-sm">
        <li><a href="/pricing" class="text-gray-600 hover:text-gray-900">Pricing</a></li>
        <li><a href="/docs" class="text-gray-600 hover:text-gray-900">Docs</a></li>
        <li><a href="/app/sign-in" class="text-gray-600 hover:text-gray-900">Sign In</a></li>
        <li>
          <a href="/app/sign-up" class="rounded-md bg-gray-900 px-4 py-2 text-white text-sm font-medium hover:bg-gray-700">
            Get Started
          </a>
        </li>
      </ul>
    </nav>
  </header>

  <main class="flex-1">
    {@inner_content}
  </main>

  <footer class="border-t border-gray-200 mt-auto">
    <p class="max-w-5xl mx-auto px-6 py-6 text-sm text-gray-400">
      &copy; 2026 Engram. All rights reserved.
    </p>
  </footer>
</body>
</html>
