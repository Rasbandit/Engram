# Ollama — GPU server
OLLAMA_URL=http://YOUR_OLLAMA_HOST:11434

# Qdrant — vector database
QDRANT_URL=http://YOUR_QDRANT_HOST:6333

# Vault path (inside container)
VAULT_PATH=/vault

# Embedding config
EMBED_MODEL=nomic-embed-text
EMBED_DIMS=768

# Indexer state (persisted volume)
STATE_DIR=/state

# Log level
LOG_LEVEL=INFO
