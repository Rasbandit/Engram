# PostgreSQL — note content storage
DATABASE_URL=postgresql://brain:brain@localhost:5432/brain

# Ollama — GPU server
OLLAMA_URL=http://YOUR_OLLAMA_HOST:11434

# Qdrant — vector database
QDRANT_URL=http://YOUR_QDRANT_HOST:6333

# Embedding config
EMBED_MODEL=nomic-embed-text
EMBED_DIMS=768
EMBED_BACKEND=ollama  # "ollama" (local, CPU or GPU) or "openai" (cloud, no GPU needed)
# OPENAI_API_KEY=sk-...       # Required if EMBED_BACKEND=openai
# OPENAI_EMBED_MODEL=text-embedding-3-small  # Default OpenAI model

# Jina reranker (optional — search falls back to vector-only if unavailable)
JINA_URL=http://YOUR_JINA_HOST:8082

# Qdrant collection name
COLLECTION=obsidian_notes

# Auth
JWT_SECRET=CHANGE_ME_TO_A_RANDOM_STRING

# Feature flags
REGISTRATION_ENABLED=true

# Log level
LOG_LEVEL=INFO

# --- Scaling / Performance ---

# PostgreSQL connection pool max size (per worker)
# PG_POOL_MAX=15

# Max note content size in bytes (default 10MB)
# MAX_NOTE_SIZE=10485760

# Background indexing (default false — sync for test compatibility)
# ASYNC_INDEXING=false

# CORS allowed origins (comma-separated, default *)
# CORS_ORIGINS=*

# Rate limit: requests per minute per user (default 120)
# RATE_LIMIT_RPM=120

# Redis (optional — enables shared state for multi-instance deployments)
# Omit or leave empty for single-instance in-memory mode
# REDIS_URL=redis://redis:6379/0
