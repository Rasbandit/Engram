# PostgreSQL — note content storage
DATABASE_URL=postgresql://brain:brain@localhost:5432/brain

# Ollama — GPU server
OLLAMA_URL=http://YOUR_OLLAMA_HOST:11434

# Qdrant — vector database
QDRANT_URL=http://YOUR_QDRANT_HOST:6333

# Embedding config
EMBED_MODEL=nomic-embed-text
EMBED_DIMS=768
EMBED_BACKEND=ollama  # "ollama" or "openai"
# OPENAI_API_KEY=sk-...  # Required if EMBED_BACKEND=openai

# Jina reranker
JINA_URL=http://YOUR_JINA_HOST:8082

# Qdrant collection name
COLLECTION=obsidian_notes

# Auth
JWT_SECRET=CHANGE_ME_TO_A_RANDOM_STRING
DB_PATH=/data/brain.db

# Feature flags
REGISTRATION_ENABLED=true

# Log level
LOG_LEVEL=INFO
