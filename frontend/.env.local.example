# Auth provider: "local" (default) or "clerk"
# In dev mode (Vite), set these VITE_* vars. In production (Phoenix-served),
# set AUTH_PROVIDER and CLERK_PUBLISHABLE_KEY as container env vars instead.
VITE_AUTH_PROVIDER=local

# Only required when VITE_AUTH_PROVIDER=clerk
# VITE_CLERK_PUBLISHABLE_KEY=pk_test_your_key_here
