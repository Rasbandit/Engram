# Required — set these before first deploy
VERSION=1.4.1
JWT_SECRET=<run: openssl rand -base64 32>
ENGRAM_IMAGE=ghcr.io/youruser/engram

# --- Optional overrides (defaults are sensible) ---
# TZ=UTC
# QDRANT_URL=http://qdrant:6333
# JINA_URL=http://jina-reranker:8082
# PG_POOL_MAX=15
# MAX_NOTE_SIZE=10485760
# ASYNC_INDEXING=false
# CORS_ORIGINS=*
# RATE_LIMIT_RPM=120
